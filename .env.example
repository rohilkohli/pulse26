# =============================================================
# Pulse26 — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# ─── Google Maps Platform ────────────────────────────────────
# Enable: Maps JavaScript API, Routes API, Places API (New)
# Restrict to HTTP referrers: localhost:*, your-deployed-domain
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# ─── Google Gemini API ───────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Model used: gemini-2.0-flash (configurable below)
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Gemini Model Config ─────────────────────────────────────
# Options: gemini-2.0-flash | gemini-2.5-flash
GEMINI_MODEL=gemini-2.0-flash

# ─── Server Config ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Digital Twin Simulator ──────────────────────────────────
# How often to push telemetry to WebSocket clients (ms)
TWIN_UPDATE_INTERVAL_MS=5000

# How often the AI alert engine runs (ms)
ALERT_ENGINE_INTERVAL_MS=30000

# ─── CORS ────────────────────────────────────────────────────
# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173
